// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id  Int @id @default(autoincrement())
  name  String
  password  String
  role  Role
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  waiterOrders Order[] @relation("WaiterOrders")
  cashierPayments Payment[] @relation("CashierPayments")

  openedShifts  Shift[] @relation("ShiftOpenedBy")
  closedShifts  Shift[] @relation("ShiftClosedBy")

  movements InventoryMovement[]
}

model Table {
  id Int @id @default(autoincrement())
  number Int @unique
  status TableStatus
  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id Int @id @default(autoincrement())
  dailyOrderNumber Int
  businessDate DateTime
  status OrderStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closeAt DateTime?

  table Table @relation(fields: [tableId], references: [id])
  tableId Int

  waiter User @relation("WaiterOrders",fields: [waiterId], references: [id])
  waiterId Int

  subOrders SubOrder[]

  @@unique([dailyOrderNumber, businessDate]) 
}

model SubOrder {
  id Int @id @default(autoincrement())
  label String
  status OrderStatus @default(OPEN)
  //subtotal Decimal @db.Decimal(10, 2)
  //total Decimal @db.Decimal(10, 2)
  paidAt DateTime?
  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  orderId Int

  orderItems OrderItem[]
  payments Payment[]
  InventoryMovements InventoryMovement[]
}

model Product {
  id Int @id @default(autoincrement())
  name String
  price Decimal @db.Decimal(10, 2)
  isActive Boolean
  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  recipes Recipe[]
  orderItems OrderItem[]
}

model Category {
  id Int @id @default(autoincrement())
  name String
  isActive Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Ingredient {
  id Int @id @default(autoincrement())
  name String
  unit Unit
  stock Decimal @db.Decimal(10, 3)
  minStockAlert Int
  isActive Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes Recipe[]
  orderItemModifiers OrderItemModifier[]
  inventoryMovements InventoryMovement[]
}

model Recipe {
  id Int @id @default(autoincrement())
  quantityRequired Decimal @db.Decimal(10, 3)

  product Product @relation(fields: [productId], references: [id])
  productId Int

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId Int

  @@unique([productId, ingredientId])
}

model OrderItem {
  id Int @id @default(autoincrement())
  quantity Int
  unitPriceSnapshot Decimal @db.Decimal(10, 2)
  totalPriceSnapshot Decimal @db.Decimal(10, 2)
  notes String?

  subOrder SubOrder @relation(fields: [subOrderId], references: [id])
  subOrderId Int
  
  product Product @relation(fields: [productId], references: [id])
  productId Int

  modifiers OrderItemModifier[]
}

model OrderItemModifier {
  id Int @id @default(autoincrement())
  quantity Decimal @db.Decimal(10, 3)
  type OrderItemModifierType

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  orderItemId Int

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId Int
}

model InventoryMovement {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  type InventoryMovementType
  quantity Decimal @db.Decimal(10, 3)

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId Int
  
  subOrder SubOrder @relation(fields: [subOrderId], references: [id])
  subOrderId Int?
  
  user User @relation(fields: [userId], references: [id])
  userId Int
}

model Shift {
  id Int @id @default(autoincrement())
  openedAt DateTime @default(now())
  closedAt DateTime?
  expectedRevenue Decimal? @db.Decimal(10, 2)
  declaredCash Decimal? @db.Decimal(10, 2)
  difference Decimal? @db.Decimal(10, 2)

  openedBy User @relation("ShiftOpenedBy",fields: [openedById], references: [id])
  openedById Int

  closedBy User? @relation("ShiftClosedBy",fields: [closedById], references: [id])
  closedById Int?

  payments Payment[]
}

model Payment {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  amount Decimal @db.Decimal(10, 2)
  method PaymentMethod

  subOrder SubOrder @relation(fields: [subOrderId], references: [id])
  subOrderId Int

  cashier User @relation("CashierPayments",fields: [cashierId], references: [id])
  cashierId Int
  
  shift Shift @relation(fields: [shiftId], references: [id])
  shiftId Int
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_PAYMENT
}

enum InventoryMovementType {
  SALE_DEDUCTION
  MANUAL_ADJUSTMENT
  WASTE
  RESTOCK
}

enum OrderItemModifierType {
  EXTRA
  REMOVE
}

enum Unit {
  UNIT
  GRAM
  KILOGRAM
  MILLILITER
  LITER
}

enum OrderStatus {
  OPEN
  SENT_TO_CASHIER
  PAID
  CANCELLED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum Role {
  ADMIN
  CASHIER
  WAITER
}